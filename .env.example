# ─── Binance ────────────────────────────────────────────
BINANCE_BASE_URL=https://api.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── Bybit ───────────────────────────────────────────────
# Urutan fallback Bybit untuk public/private endpoint
BYBIT_BASE_URLS=https://api.bytick.com,https://api.bybit.id,https://api.bybit.com
# Single URL fallback lama tetap didukung kalau BYBIT_BASE_URLS tidak diisi
BYBIT_BASE_URL=https://api.bytick.com
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_DISABLE_PUBLIC=0

# ─── Futures Market Data Chain ──────────────────────────
# Urutan provider publik futures: bitget, okx, kucoin, hyperliquid
FUTURES_DATA_PROVIDER_ORDER=bitget,okx,kucoin,hyperliquid
# Hyperliquid opsional; matikan kalau mau CEX-only
FUTURES_DATA_ENABLE_HYPERLIQUID=1
# Optional: aktifkan Binance cuma kalau region lo memang bisa akses
FUTURES_DATA_ENABLE_BINANCE_FALLBACK=0
BITGET_BASE_URL=https://api.bitget.com
OKX_BASE_URL=https://www.okx.com
KUCOIN_BASE_URL=https://api-futures.kucoin.com
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
FUTURES_PROVIDER_BLOCK_COOLDOWN_MS=900000
FUTURES_PROVIDER_TRANSIENT_COOLDOWN_MS=120000

# ─── OpenRouter (AI) ────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── Discord ─────────────────────────────────────────────
# Webhook URLs (dari Discord Server → Edit Channel → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
DISCORD_SIGNAL_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
DISCORD_STATUS_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# Discord App / Slash Commands
DISCORD_APPLICATION_ID=123456789012345678
DISCORD_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DISCORD_BOT_TOKEN=BotTokenHere
DISCORD_GUILD_ID=

# ─── Telegram ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABCDEF
TELEGRAM_CHAT_ID=-1001234567890

# ─── Cron Auth ──────────────────────────────────────────
CRON_SECRET=replace-with-a-long-random-secret
CHECK_SIGNAL_URL=https://crypto-signal-bot-blush.vercel.app/api/check-signal
SCAN_TRIGGER_TIMEOUT_MS=2500

# ─── Runtime Mode ───────────────────────────────────────
# Set ke 1 hanya kalau mau matiin background runtime persistent di VM.
DISABLE_BACKGROUND_RUNTIME=0

# ─── Upstash Redis (State Persistence) ──────────────────
# Dari https://upstash.com → Database → REST API tab
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxx

# ─── Scanner Config ─────────────────────────────────────
SCAN_INTERVAL_MS=3600000
TOP_SIGNALS_TO_AI=3
MAX_PAIRS=30

# ─── Storage (local dev only) ────────────────────────────
DATA_DIR=

# ─── Strategy ───────────────────────────────────────────
ACCOUNT_BALANCE=4
RISK_PERCENTAGE=0.02
MAX_POSITION_PERCENTAGE=0.05
MIN_RR_RATIO=1.5

# ─── Logging ────────────────────────────────────────────
LOG_LEVEL=info
